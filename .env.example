####################################################################
# TalentMatch AI — environment variables
#
# Copy to .env and fill in the blanks. `.env` is in .gitignore.
# Never commit real secrets.
####################################################################

# ----- General -----
NODE_ENV=production
LOG_LEVEL=info

# ----- Postgres (internal only, not exposed to host) -----
POSTGRES_USER=talentmatch
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=talentmatch

# ----- Backend / JWT -----
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_RANDOM
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# ----- Internal API key shared between Node and FastAPI -----
# Generate with: openssl rand -base64 48
INTERNAL_API_KEY=CHANGE_ME_AT_LEAST_32_CHARS_LONG_RANDOM

# ----- Frontend origin (strict CORS allowlist) -----
# In production set this to your real domain.
FRONTEND_URL=http://localhost:5173

# ----- Uploads -----
MAX_UPLOAD_BYTES=5242880
